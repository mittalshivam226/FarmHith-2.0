# =================================================
# FarmHith API — Environment Variables
# Copy this file to .env and fill in your values
# =================================================

# ---- Database ----
# PostgreSQL connection string (Neon / Supabase / local)
DATABASE_URL="postgresql://postgres:password@localhost:5432/farmhith"

# ---- Server ----
PORT=4000
NODE_ENV=development

# ---- JWT ----
JWT_SECRET="replace-with-a-very-long-random-secret-string-at-least-64-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ---- CORS ----
# Comma-separated frontend origins to allow
ALLOWED_ORIGINS="http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004,http://localhost:3005"

# ---- OTP (Mock) ----
# In production, replace with Twilio / MSG91 / Fast2SMS credentials
OTP_BYPASS_CODE="123456"
