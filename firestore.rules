rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ───────────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Cached single get — avoids billing two reads per rule evaluation.
    // Must be called only when isSignedIn() is guaranteed true.
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isRole(role) {
      return isSignedIn() && getUserRole() == role;
    }

    function isAdmin() {
      return isRole('ADMIN');
    }

    // ─── /users/{uid} ──────────────────────────────────────────────────────────
    // Owner reads/writes their own doc. Admin reads all. Nobody else writes.

    match /users/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── /farmerProfiles/{uid} ─────────────────────────────────────────────────

    match /farmerProfiles/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isRole('FARMER');
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── /labProfiles/{uid} ────────────────────────────────────────────────────
    // Labs are discoverable by any authenticated user so farmers can browse & book.

    match /labProfiles/{uid} {
      allow read:   if isSignedIn();
      allow create: if isOwner(uid) && isRole('LAB');
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── /soilmitraProfiles/{uid} ──────────────────────────────────────────────
    // Mitras are discoverable by any authenticated user so farmers can browse.

    match /soilmitraProfiles/{uid} {
      allow read:   if isSignedIn();
      allow create: if isOwner(uid) && isRole('SOILMITRA');
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── /biopelletProfiles/{uid} ──────────────────────────────────────────────
    // Readable by authenticated FARMER and ADMIN (for marketplace).

    match /biopelletProfiles/{uid} {
      allow read:   if isOwner(uid) || isRole('FARMER') || isAdmin();
      allow create: if isOwner(uid) && isRole('BIOPELLET');
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if isAdmin();
    }

    // ─── /soilTestBookings/{bookingId} ─────────────────────────────────────────
    // Farmer creates; farmer and the assigned lab can read/update.

    match /soilTestBookings/{bookingId} {
      allow create: if isRole('FARMER')
                    && request.resource.data.farmerId == request.auth.uid;

      allow read:   if isSignedIn() && (
                      resource.data.farmerId == request.auth.uid ||
                      resource.data.labId    == request.auth.uid ||
                      isAdmin()
                    );

      // Lab updates status to ACCEPTED / IN_PROGRESS / COMPLETED.
      // Farmer can update reportConsentToMitra only.
      allow update: if isSignedIn() && (
                      resource.data.labId    == request.auth.uid ||
                      resource.data.farmerId == request.auth.uid ||
                      isAdmin()
                    );

      allow delete: if isAdmin();

      // ── /soilTestBookings/{bookingId}/reports/{reportId} ──────────────────────
      // Lab writes; farmer reads; Mitra reads ONLY when farmerConsentedReport == true.

      match /reports/{reportId} {
        allow create, update: if isRole('LAB')
                              && get(/databases/$(database)/documents/soilTestBookings/$(bookingId)).data.labId == request.auth.uid;

        allow read: if isSignedIn() && (
          // Farmer who owns the booking
          get(/databases/$(database)/documents/soilTestBookings/$(bookingId)).data.farmerId == request.auth.uid
          ||
          // Lab who submitted the report
          get(/databases/$(database)/documents/soilTestBookings/$(bookingId)).data.labId == request.auth.uid
          ||
          // Mitra — ONLY if farmer gave consent on the parent booking
          (
            isRole('SOILMITRA') &&
            get(/databases/$(database)/documents/soilTestBookings/$(bookingId)).data.reportConsentToMitra == true
          )
          ||
          isAdmin()
        );

        allow delete: if isAdmin();
      }
    }

    // ─── /mitraBookings/{bookingId} ────────────────────────────────────────────
    // Farmer creates; farmer and mitra can read/update their respective fields.

    match /mitraBookings/{bookingId} {
      allow create: if isRole('FARMER')
                    && request.resource.data.farmerId == request.auth.uid;

      allow read:   if isSignedIn() && (
                      resource.data.farmerId == request.auth.uid ||
                      resource.data.mitraId  == request.auth.uid ||
                      isAdmin()
                    );

      // Mitra can update status, notes, videoRoomUrl.
      // Farmer can update farmerRating and farmerConsentedReport.
      allow update: if isSignedIn() && (
                      resource.data.mitraId  == request.auth.uid ||
                      resource.data.farmerId == request.auth.uid ||
                      isAdmin()
                    );

      allow delete: if isAdmin();
    }

    // ─── /cropListings/{listingId} ─────────────────────────────────────────────
    // Farmer creates/owns; any authenticated user (biopellet plant) can read for marketplace browsing.

    match /cropListings/{listingId} {
      allow create: if isRole('FARMER')
                    && request.resource.data.farmerId == request.auth.uid;

      allow read:   if isSignedIn();

      allow update: if isSignedIn() && (
                      resource.data.farmerId == request.auth.uid ||
                      isRole('BIOPELLET')   ||   // plant can mark MATCHED / SOLD
                      isAdmin()
                    );

      allow delete: if isSignedIn() && resource.data.farmerId == request.auth.uid
                    || isAdmin();
    }

    // ─── /procurementOrders/{orderId} ──────────────────────────────────────────
    // Biopellet plant creates; farmer and plant can read/update.

    match /procurementOrders/{orderId} {
      allow create: if isRole('BIOPELLET')
                    && request.resource.data.plantId == request.auth.uid;

      allow read:   if isSignedIn() && (
                      resource.data.plantId  == request.auth.uid ||
                      resource.data.farmerId == request.auth.uid ||
                      isAdmin()
                    );

      allow update: if isSignedIn() && (
                      resource.data.farmerId == request.auth.uid ||
                      resource.data.plantId  == request.auth.uid ||
                      isAdmin()
                    );

      allow delete: if isAdmin();
    }

    // ─── /payments/{paymentId} ─────────────────────────────────────────────────
    // Payments are created server-side (Cloud Functions or Admin SDK only).
    // Clients can only read their own payments.

    match /payments/{paymentId} {
      allow create: if isAdmin();
      allow read:   if isSignedIn() && (
                      resource.data.payerUid == request.auth.uid ||
                      resource.data.payeeUid == request.auth.uid ||
                      isAdmin()
                    );
      allow update, delete: if isAdmin();
    }

    // ─── /notifications/{notifId} ──────────────────────────────────────────────
    // Written by Admin SDK; users read their own and can flip `read` field only.

    match /notifications/{notifId} {
      allow read:   if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isSignedIn()
                    && resource.data.userId == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ─── /soilReports/{bookingId} ──────────────────────────────────────────────
    // Top-level mirror of sub-collection reports, written by Lab via Admin SDK.
    // Farmer reads; Mitra reads when consent given; Admin reads all.

    match /soilReports/{bookingId} {
      allow read: if isSignedIn() && (
        // Farmer whose booking this is
        get(/databases/$(database)/documents/soilTestBookings/$(bookingId)).data.farmerId == request.auth.uid
        ||
        // Lab who ran the test
        get(/databases/$(database)/documents/soilTestBookings/$(bookingId)).data.labId == request.auth.uid
        ||
        // Mitra — ONLY if farmer gave explicit consent
        (
          isRole('SOILMITRA') &&
          get(/databases/$(database)/documents/soilTestBookings/$(bookingId)).data.reportConsentToMitra == true
        )
        ||
        isAdmin()
      );
      // Written exclusively by Admin SDK (server-side) — no client writes
      allow create, update: if false;
      allow delete: if isAdmin();
    }

    // ─── /disputes/{disputeId} ─────────────────────────────────────────────────
    // Created and updated exclusively by Admin users and Admin SDK.

    match /disputes/{disputeId} {
      allow read, create, update, delete: if isAdmin();
    }

    // ─── /broadcasts/{broadcastId} ─────────────────────────────────────────────
    // Created by Admin SDK only; admin users can read broadcast history.

    match /broadcasts/{broadcastId} {
      allow read, create, update, delete: if isAdmin();
    }

  }
}
